<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Corporación Planeta Libre – CORPLANETL | Turismo Sostenible, Bolombolo, Antioquia</title>
<meta name="description" content="CORPLANETL promueve el ecoturismo, la conservación ambiental y el desarrollo comunitario en Bolombolo, Venecia, Antioquia. Experiencias turísticas sostenibles conectadas con la naturaleza y la cultura.">
<meta name="keywords" content="turismo sostenible, ecoturismo, Bolombolo, Venecia, Antioquia, conservación, comunidad, naturaleza, Río Cauca">
<meta property="og:title" content="Corporación Planeta Libre – CORPLANETL">
<meta property="og:description" content="Turismo sostenible que transforma vidas y protege el planeta en Bolombolo, Antioquia.">
<meta property="og:type" content="website">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

<style>
/* =============================================
   VARIABLES Y RESET
============================================= */
:root {
  --verde-esmeralda: #2E7D32;
  --verde-musgo: #4E6B43;
  --verde-claro: #43A047;
  --verde-hover: #1B5E20;
  --azul-turquesa: #1CA9C9;
  --azul-oscuro: #0D7A96;
  --marron: #8D6E63;
  --terracota: #C76B3C;
  --terracota-hover: #A0522D;
  --blanco: #FFFFFF;
  --gris-claro: #F5F5F5;
  --gris-medio: #E8E8E8;
  --gris-texto: #666;
  --negro: #1A1A1A;
  --sombra: 0 4px 24px rgba(0,0,0,0.10);
  --sombra-hover: 0 8px 32px rgba(0,0,0,0.18);
  --radio: 12px;
  --radio-sm: 8px;
  --transicion: all 0.3s cubic-bezier(0.4,0,0.2,1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: 'Lato', sans-serif;
  color: var(--negro);
  background: var(--blanco);
  line-height: 1.7;
  overflow-x: hidden;
}

h1,h2,h3,h4,h5 {
  font-family: 'Montserrat', sans-serif;
  line-height: 1.2;
}

img { max-width: 100%; display: block; }
a { text-decoration: none; color: inherit; }
ul { list-style: none; }

/* =============================================
   UTILIDADES
============================================= */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.section { padding: 90px 0; }
.section-alt { background: var(--gris-claro); }

.section-badge {
  display: inline-block;
  background: rgba(46,125,50,0.10);
  color: var(--verde-esmeralda);
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 6px 16px;
  border-radius: 50px;
  margin-bottom: 16px;
}

.section-title {
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 800;
  color: var(--negro);
  margin-bottom: 16px;
}

.section-subtitle {
  font-size: 18px;
  color: var(--gris-texto);
  max-width: 620px;
  line-height: 1.7;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  border-radius: 50px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  font-size: 14px;
  cursor: pointer;
  border: none;
  transition: var(--transicion);
  letter-spacing: 0.5px;
}

.btn-primary {
  background: var(--verde-esmeralda);
  color: var(--blanco);
}
.btn-primary:hover { background: var(--verde-hover); transform: translateY(-2px); box-shadow: var(--sombra-hover); }

.btn-secondary {
  background: transparent;
  color: var(--blanco);
  border: 2px solid rgba(255,255,255,0.7);
}
.btn-secondary:hover { background: rgba(255,255,255,0.15); transform: translateY(-2px); }

.btn-outline {
  background: transparent;
  color: var(--verde-esmeralda);
  border: 2px solid var(--verde-esmeralda);
}
.btn-outline:hover { background: var(--verde-esmeralda); color: var(--blanco); }

.btn-terracota {
  background: var(--terracota);
  color: var(--blanco);
}
.btn-terracota:hover { background: var(--terracota-hover); transform: translateY(-2px); box-shadow: var(--sombra-hover); }

.btn-whatsapp {
  background: #25D366;
  color: var(--blanco);
}
.btn-whatsapp:hover { background: #1DA851; transform: translateY(-2px); }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }

/* =============================================
   HEADER / NAV
============================================= */
#header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  transition: var(--transicion);
  padding: 0;
}

#header.scrolled {
  background: rgba(255,255,255,0.97);
  box-shadow: 0 2px 20px rgba(0,0,0,0.10);
  backdrop-filter: blur(12px);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 24px;
  max-width: 1200px;
  margin: 0 auto;
}

.logo {
  display: flex;
  align-items: center;
  gap: 14px;
}

.logo-icon {
  width: 52px;
  height: 52px;
  flex-shrink: 0;
}

.logo-text-wrap { display: flex; flex-direction: column; line-height: 1.1; }

.logo-name {
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 15px;
  color: var(--verde-esmeralda);
  letter-spacing: 0.5px;
  transition: var(--transicion);
}

#header:not(.scrolled) .logo-name { color: var(--blanco); }

.logo-sigla {
  font-family: 'Montserrat', sans-serif;
  font-weight: 400;
  font-size: 11px;
  color: var(--azul-turquesa);
  letter-spacing: 3px;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 6px;
}

.nav-links a {
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  font-weight: 600;
  padding: 8px 14px;
  border-radius: 50px;
  color: var(--blanco);
  transition: var(--transicion);
  letter-spacing: 0.3px;
}

#header.scrolled .nav-links a { color: var(--negro); }

.nav-links a:hover {
  background: rgba(255,255,255,0.15);
  color: var(--blanco);
}

#header.scrolled .nav-links a:hover {
  background: var(--gris-claro);
  color: var(--verde-esmeralda);
}

.nav-cta {
  background: var(--verde-esmeralda) !important;
  color: var(--blanco) !important;
}
.nav-cta:hover { background: var(--verde-hover) !important; }

.nav-social { display: flex; align-items: center; gap: 8px; }
.nav-social a {
  width: 34px; height: 34px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  color: rgba(255,255,255,0.8);
  font-size: 14px;
  transition: var(--transicion);
  background: rgba(255,255,255,0.10);
}
#header.scrolled .nav-social a { color: var(--gris-texto); background: var(--gris-claro); }
.nav-social a:hover { background: var(--verde-esmeralda); color: var(--blanco) !important; }

.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 8px;
}
.nav-hamburger span {
  width: 26px; height: 2px;
  background: var(--blanco);
  border-radius: 2px;
  transition: var(--transicion);
}
#header.scrolled .nav-hamburger span { background: var(--negro); }

/* =============================================
   HERO
============================================= */
#hero {
  min-height: 100vh;
  position: relative;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(135deg, rgba(27,94,32,0.92) 0%, rgba(13,122,150,0.78) 50%, rgba(78,107,67,0.88) 100%),
    url('https://images.unsplash.com/photo-1501854140801-50d01698950b?w=1600&q=80') center/cover no-repeat;
}

.hero-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.05;
  background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%);
  background-size: 20px 20px;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 140px 0 100px;
  max-width: 780px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.25);
  color: var(--blanco);
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 8px 20px;
  border-radius: 50px;
  margin-bottom: 28px;
  animation: fadeUp 0.8s ease forwards;
}

.hero-badge .dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #4CAF50;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%,100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.3); }
}

.hero-title {
  font-size: clamp(36px, 6vw, 68px);
  font-weight: 800;
  color: var(--blanco);
  line-height: 1.08;
  margin-bottom: 24px;
  animation: fadeUp 0.9s ease 0.1s both;
}

.hero-title em {
  font-style: normal;
  color: #81C784;
}

.hero-subtitle {
  font-size: 20px;
  color: rgba(255,255,255,0.85);
  margin-bottom: 40px;
  max-width: 580px;
  line-height: 1.6;
  animation: fadeUp 1s ease 0.2s both;
}

.hero-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  animation: fadeUp 1s ease 0.3s both;
}

.hero-stats {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 40px;
  margin-top: 60px;
  padding-top: 40px;
  border-top: 1px solid rgba(255,255,255,0.20);
  animation: fadeUp 1s ease 0.4s both;
}

.hero-stat-item { text-align: left; }
.hero-stat-num {
  font-family: 'Montserrat', sans-serif;
  font-size: 38px;
  font-weight: 800;
  color: var(--blanco);
  line-height: 1;
}
.hero-stat-label {
  font-size: 13px;
  color: rgba(255,255,255,0.70);
  margin-top: 4px;
  font-weight: 400;
}

.hero-scroll {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: rgba(255,255,255,0.60);
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-family: 'Montserrat', sans-serif;
  cursor: pointer;
}

.hero-scroll-line {
  width: 1px; height: 50px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
  animation: scrollLine 2s ease infinite;
}

@keyframes scrollLine {
  0% { transform: scaleY(0); transform-origin: top; }
  50% { transform: scaleY(1); transform-origin: top; }
  51% { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

/* =============================================
   LOGO SVG
============================================= */
.logo-svg-el { display: block; }

/* =============================================
   QUIÉNES SOMOS
============================================= */
.about-visual {
  position: relative;
}

.about-img-main {
  border-radius: var(--radio);
  overflow: hidden;
  aspect-ratio: 4/5;
  background: var(--verde-musgo);
}

.about-img-main img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.about-img-main:hover img { transform: scale(1.04); }

.about-card-float {
  position: absolute;
  bottom: -24px;
  right: -24px;
  background: var(--blanco);
  border-radius: var(--radio);
  padding: 24px 28px;
  box-shadow: var(--sombra-hover);
  max-width: 240px;
}

.about-card-float .num {
  font-family: 'Montserrat', sans-serif;
  font-size: 42px;
  font-weight: 800;
  color: var(--verde-esmeralda);
  line-height: 1;
}

.about-card-float .label {
  font-size: 14px;
  color: var(--gris-texto);
  margin-top: 4px;
}

.about-values {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 32px;
}

.about-value-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px;
  background: var(--gris-claro);
  border-radius: var(--radio-sm);
  transition: var(--transicion);
}
.about-value-item:hover {
  background: rgba(46,125,50,0.06);
  transform: translateY(-2px);
}

.about-value-icon {
  width: 40px; height: 40px;
  border-radius: 10px;
  background: rgba(46,125,50,0.12);
  color: var(--verde-esmeralda);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.about-value-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  font-weight: 700;
  margin-bottom: 4px;
}
.about-value-desc {
  font-size: 12px;
  color: var(--gris-texto);
  line-height: 1.5;
}

/* =============================================
   LÍNEAS DE ACCIÓN
============================================= */
.action-tabs {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}

.action-tab {
  padding: 10px 20px;
  border-radius: 50px;
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  border: 2px solid var(--gris-medio);
  background: var(--blanco);
  color: var(--gris-texto);
  transition: var(--transicion);
}

.action-tab.active, .action-tab:hover {
  background: var(--verde-esmeralda);
  border-color: var(--verde-esmeralda);
  color: var(--blanco);
}

.action-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 24px;
}

.action-card {
  background: var(--blanco);
  border-radius: var(--radio);
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  transition: var(--transicion);
  border: 1px solid var(--gris-medio);
}

.action-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--sombra-hover);
}

.action-card-img {
  height: 180px;
  background: var(--verde-musgo);
  overflow: hidden;
  position: relative;
}

.action-card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.action-card:hover .action-card-img img { transform: scale(1.08); }

.action-card-badge {
  position: absolute;
  top: 12px; left: 12px;
  background: var(--verde-esmeralda);
  color: var(--blanco);
  font-size: 11px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 50px;
  font-family: 'Montserrat', sans-serif;
  letter-spacing: 0.5px;
}

.action-card-body { padding: 20px; }
.action-card-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 16px;
  margin-bottom: 8px;
  color: var(--negro);
}
.action-card-desc { font-size: 14px; color: var(--gris-texto); line-height: 1.6; }

/* =============================================
   PLANES TURÍSTICOS
============================================= */
#planes { background: var(--gris-claro); }

.category-tabs {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

.cat-tab {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 22px;
  border-radius: 50px;
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  border: 2px solid var(--gris-medio);
  background: var(--blanco);
  color: var(--gris-texto);
  transition: var(--transicion);
}
.cat-tab .icon { font-size: 16px; }
.cat-tab.active, .cat-tab:hover {
  background: var(--verde-esmeralda);
  border-color: var(--verde-esmeralda);
  color: var(--blanco);
  box-shadow: 0 4px 16px rgba(46,125,50,0.30);
}

.planes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
  gap: 28px;
}

.plan-card {
  background: var(--blanco);
  border-radius: var(--radio);
  overflow: hidden;
  box-shadow: var(--sombra);
  transition: var(--transicion);
  border: 1px solid var(--gris-medio);
}
.plan-card:hover { transform: translateY(-8px); box-shadow: var(--sombra-hover); }

.plan-card-img {
  height: 220px;
  position: relative;
  overflow: hidden;
}
.plan-card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.plan-card:hover .plan-card-img img { transform: scale(1.06); }

.plan-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);
}

.plan-card-tags {
  position: absolute;
  top: 12px; left: 12px;
  display: flex; gap: 6px;
}
.plan-tag {
  background: rgba(255,255,255,0.90);
  color: var(--verde-esmeralda);
  font-family: 'Montserrat', sans-serif;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 50px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.plan-difficulty {
  position: absolute;
  top: 12px; right: 12px;
  padding: 4px 12px;
  border-radius: 50px;
  font-family: 'Montserrat', sans-serif;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
}
.diff-facil { background: #E8F5E9; color: #2E7D32; }
.diff-moderado { background: #FFF8E1; color: #F57F17; }
.diff-dificil { background: #FCE4EC; color: #B71C1C; }

.plan-price-badge {
  position: absolute;
  bottom: 12px; right: 12px;
  background: var(--verde-esmeralda);
  color: var(--blanco);
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 18px;
  padding: 6px 16px;
  border-radius: 8px;
}

.plan-card-body { padding: 24px; }
.plan-card-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 20px;
  margin-bottom: 8px;
  color: var(--negro);
}
.plan-card-desc {
  font-size: 14px;
  color: var(--gris-texto);
  line-height: 1.6;
  margin-bottom: 16px;
}

.plan-meta {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  padding: 12px 0;
  border-top: 1px solid var(--gris-medio);
  border-bottom: 1px solid var(--gris-medio);
  margin-bottom: 16px;
}
.plan-meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: var(--gris-texto);
}
.plan-meta-item .ico { font-size: 15px; color: var(--verde-esmeralda); }

.plan-includes {
  margin-bottom: 20px;
}
.plan-includes-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--negro);
  margin-bottom: 8px;
}
.plan-includes-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.plan-includes-item {
  font-size: 12px;
  color: var(--verde-musgo);
  background: rgba(78,107,67,0.08);
  padding: 3px 10px;
  border-radius: 50px;
}
.plan-includes-item.no {
  color: var(--marron);
  background: rgba(141,110,99,0.08);
  text-decoration: line-through;
}

.plan-actions {
  display: flex;
  gap: 10px;
}
.plan-actions .btn { flex: 1; justify-content: center; padding: 12px; font-size: 13px; }

/* =============================================
   GALERÍA
============================================= */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: repeat(2, 220px);
  gap: 12px;
}
.gallery-item {
  border-radius: var(--radio-sm);
  overflow: hidden;
  position: relative;
  cursor: pointer;
}
.gallery-item:nth-child(1) { grid-column: span 2; grid-row: span 2; }
.gallery-item:nth-child(2) { grid-column: span 2; }

.gallery-item img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.gallery-item:hover img { transform: scale(1.08); }

.gallery-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0);
  transition: var(--transicion);
  display: flex;
  align-items: center;
  justify-content: center;
}
.gallery-item:hover .gallery-overlay {
  background: rgba(46,125,50,0.45);
}
.gallery-overlay-icon {
  color: var(--blanco);
  font-size: 32px;
  opacity: 0;
  transform: scale(0.7);
  transition: var(--transicion);
}
.gallery-item:hover .gallery-overlay-icon {
  opacity: 1;
  transform: scale(1);
}

/* =============================================
   IMPACTO / STATS
============================================= */
.impact-section {
  background: linear-gradient(135deg, var(--verde-esmeralda) 0%, var(--verde-musgo) 60%, var(--azul-oscuro) 100%);
  position: relative;
  overflow: hidden;
}
.impact-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.03) 0, rgba(255,255,255,0.03) 1px, transparent 0, transparent 50%);
  background-size: 30px 30px;
}

.impact-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
  position: relative;
  z-index: 1;
}

.impact-item { text-align: center; }
.impact-num {
  font-family: 'Montserrat', sans-serif;
  font-size: 56px;
  font-weight: 800;
  color: var(--blanco);
  line-height: 1;
  margin-bottom: 8px;
}
.impact-label {
  font-size: 15px;
  color: rgba(255,255,255,0.75);
}

/* =============================================
   TRANSPARENCIA
============================================= */
.trans-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 40px;
}
.trans-card {
  background: var(--blanco);
  border: 1px solid var(--gris-medio);
  border-radius: var(--radio);
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: var(--transicion);
}
.trans-card:hover {
  border-color: var(--verde-esmeralda);
  box-shadow: 0 4px 20px rgba(46,125,50,0.12);
  transform: translateY(-4px);
}
.trans-card-icon {
  width: 52px; height: 52px;
  background: rgba(46,125,50,0.10);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  color: var(--verde-esmeralda);
}
.trans-card-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 16px;
}
.trans-card-desc { font-size: 14px; color: var(--gris-texto); }
.trans-card-link {
  color: var(--verde-esmeralda);
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: auto;
  transition: var(--transicion);
}
.trans-card-link:hover { gap: 10px; }

/* =============================================
   DONACIONES
============================================= */
#donaciones {
  background: linear-gradient(135deg, #1B5E20 0%, #0D7A96 100%);
  position: relative;
  overflow: hidden;
}
#donaciones::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url('https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?w=1400&q=60') center/cover;
  opacity: 0.10;
}

.donaciones-inner {
  position: relative;
  z-index: 1;
  text-align: center;
}
.donaciones-inner .section-title { color: var(--blanco); }
.donaciones-inner .section-subtitle { color: rgba(255,255,255,0.80); margin: 0 auto 48px; }

.donaciones-options {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16px;
}

.don-card {
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.20);
  border-radius: var(--radio);
  padding: 28px 16px;
  text-align: center;
  cursor: pointer;
  transition: var(--transicion);
  color: var(--blanco);
}
.don-card:hover {
  background: rgba(255,255,255,0.20);
  transform: translateY(-6px);
  border-color: rgba(255,255,255,0.50);
}
.don-card-icon { font-size: 32px; margin-bottom: 12px; }
.don-card-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 15px;
  margin-bottom: 8px;
}
.don-card-desc { font-size: 13px; color: rgba(255,255,255,0.75); line-height: 1.5; }

/* =============================================
   BLOG
============================================= */
.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }

.blog-card {
  background: var(--blanco);
  border-radius: var(--radio);
  overflow: hidden;
  border: 1px solid var(--gris-medio);
  transition: var(--transicion);
}
.blog-card:hover { transform: translateY(-6px); box-shadow: var(--sombra-hover); }

.blog-card-img {
  height: 200px;
  overflow: hidden;
}
.blog-card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.blog-card:hover .blog-card-img img { transform: scale(1.06); }

.blog-card-body { padding: 24px; }
.blog-card-cat {
  font-family: 'Montserrat', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--verde-esmeralda);
  margin-bottom: 10px;
}
.blog-card-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 17px;
  margin-bottom: 10px;
  color: var(--negro);
  line-height: 1.4;
}
.blog-card-excerpt { font-size: 14px; color: var(--gris-texto); line-height: 1.6; margin-bottom: 16px; }
.blog-card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 12px;
  color: var(--gris-texto);
  padding-top: 12px;
  border-top: 1px solid var(--gris-medio);
}

/* =============================================
   RESERVAS
============================================= */
#reservas { background: var(--gris-claro); }

.reservas-wrap {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 60px;
  align-items: start;
}

.reservas-info h3 {
  font-size: 28px;
  font-weight: 800;
  color: var(--negro);
  margin-bottom: 16px;
}

.reservas-features {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 32px;
}
.reservas-feature {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px;
  background: var(--blanco);
  border-radius: var(--radio-sm);
  border: 1px solid var(--gris-medio);
}
.reservas-feature-icon {
  width: 42px; height: 42px;
  background: rgba(46,125,50,0.10);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  color: var(--verde-esmeralda);
  flex-shrink: 0;
}
.reservas-feature-text strong {
  display: block;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 14px;
  margin-bottom: 2px;
}
.reservas-feature-text span { font-size: 13px; color: var(--gris-texto); }

.reservas-form {
  background: var(--blanco);
  border-radius: var(--radio);
  padding: 40px;
  box-shadow: var(--sombra);
  border: 1px solid var(--gris-medio);
}

.form-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 800;
  font-size: 22px;
  margin-bottom: 28px;
  color: var(--negro);
}

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group { margin-bottom: 16px; }

.form-group label {
  display: block;
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--negro);
  margin-bottom: 6px;
}

.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 12px 16px;
  border: 1.5px solid var(--gris-medio);
  border-radius: var(--radio-sm);
  font-family: 'Lato', sans-serif;
  font-size: 15px;
  color: var(--negro);
  background: var(--gris-claro);
  transition: var(--transicion);
  outline: none;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--verde-esmeralda);
  background: var(--blanco);
  box-shadow: 0 0 0 3px rgba(46,125,50,0.12);
}
.form-group textarea { resize: vertical; min-height: 100px; }

/* =============================================
   CONTACTO
============================================= */
.contacto-wrap {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 60px;
  align-items: start;
}

.contacto-info { }
.contacto-detail {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 20px 0;
  border-bottom: 1px solid var(--gris-medio);
}
.contacto-detail:last-child { border-bottom: none; }

.contacto-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  background: rgba(46,125,50,0.10);
  color: var(--verde-esmeralda);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.contacto-text-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--gris-texto);
  margin-bottom: 4px;
}
.contacto-text-value {
  font-size: 15px;
  color: var(--negro);
  font-weight: 400;
}
.contacto-text-value a { color: var(--verde-esmeralda); }

.map-container {
  border-radius: var(--radio);
  overflow: hidden;
  height: 300px;
  background: var(--gris-medio);
  margin-top: 24px;
  border: 1px solid var(--gris-medio);
}
.map-container iframe { width: 100%; height: 100%; border: none; }

/* =============================================
   FOOTER
============================================= */
footer {
  background: #0D1F0E;
  color: rgba(255,255,255,0.80);
  padding: 72px 0 0;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 48px;
}

.footer-brand .logo-name { color: var(--blanco) !important; }
.footer-brand .logo-sigla { color: var(--azul-turquesa) !important; }

.footer-desc {
  font-size: 14px;
  color: rgba(255,255,255,0.60);
  line-height: 1.7;
  margin: 20px 0 24px;
}

.footer-social { display: flex; gap: 10px; }
.footer-social a {
  width: 38px; height: 38px;
  border-radius: 10px;
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.70);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
  transition: var(--transicion);
}
.footer-social a:hover { background: var(--verde-esmeralda); color: var(--blanco); }

.footer-col-title {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 14px;
  color: var(--blanco);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 20px;
}

.footer-links { display: flex; flex-direction: column; gap: 10px; }
.footer-links a {
  font-size: 14px;
  color: rgba(255,255,255,0.60);
  transition: var(--transicion);
}
.footer-links a:hover { color: var(--blanco); padding-left: 4px; }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 24px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 13px;
  color: rgba(255,255,255,0.40);
}

/* =============================================
   BOTONES FLOTANTES
============================================= */
.floating-buttons {
  position: fixed;
  right: 24px;
  bottom: 32px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  z-index: 900;
}

.float-btn {
  width: 52px; height: 52px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  color: var(--blanco);
  cursor: pointer;
  transition: var(--transicion);
  box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  text-decoration: none;
}
.float-btn:hover { transform: scale(1.12); box-shadow: 0 8px 24px rgba(0,0,0,0.30); }
.float-wa { background: #25D366; }
.float-top { background: var(--verde-esmeralda); font-size: 18px; }

/* =============================================
   MODAL RESERVA
============================================= */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.65);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.modal-overlay.open {
  opacity: 1;
  pointer-events: all;
}
.modal-box {
  background: var(--blanco);
  border-radius: var(--radio);
  padding: 40px;
  max-width: 560px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  transform: translateY(30px);
  transition: transform 0.3s ease;
}
.modal-overlay.open .modal-box { transform: translateY(0); }
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28px;
}
.modal-title {
  font-family: 'Montserrat', sans-serif;
  font-size: 22px;
  font-weight: 800;
  color: var(--negro);
}
.modal-close {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: var(--gris-claro);
  border: none;
  cursor: pointer;
  font-size: 18px;
  display: flex; align-items: center; justify-content: center;
  color: var(--gris-texto);
  transition: var(--transicion);
}
.modal-close:hover { background: var(--gris-medio); }

/* =============================================
   MOBILE NAV
============================================= */
.mobile-nav {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(15,30,15,0.97);
  z-index: 1500;
  padding: 80px 32px;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.mobile-nav.open { display: flex; }
.mobile-nav a {
  font-family: 'Montserrat', sans-serif;
  font-size: 22px;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  width: 100%;
  text-align: center;
  transition: var(--transicion);
}
.mobile-nav a:hover { color: #81C784; }
.mobile-nav-close {
  position: absolute;
  top: 24px; right: 24px;
  width: 44px; height: 44px;
  border-radius: 50%;
  background: rgba(255,255,255,0.10);
  border: none; cursor: pointer;
  font-size: 20px; color: var(--blanco);
  display: flex; align-items: center; justify-content: center;
}

/* =============================================
   RESPONSIVE
============================================= */
@media (max-width: 1024px) {
  .grid-4 { grid-template-columns: repeat(2, 1fr); }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .donaciones-options { grid-template-columns: repeat(3, 1fr); }
  .impact-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
  .nav-links, .nav-social { display: none; }
  .nav-hamburger { display: flex; }
  .section { padding: 60px 0; }
  .grid-2 { grid-template-columns: 1fr; }
  .grid-3 { grid-template-columns: 1fr; }
  .blog-grid { grid-template-columns: 1fr; }
  .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
  .gallery-item:nth-child(1) { grid-column: span 2; grid-row: auto; }
  .gallery-item:nth-child(2) { grid-column: span 2; }
  .trans-cards { grid-template-columns: 1fr; }
  .donaciones-options { grid-template-columns: 1fr 1fr; }
  .reservas-wrap { grid-template-columns: 1fr; }
  .contacto-wrap { grid-template-columns: 1fr; }
  .hero-stats { gap: 24px; flex-wrap: wrap; }
  .planes-grid { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .about-card-float { position: relative; bottom: auto; right: auto; margin-top: 16px; max-width: 100%; }
  .footer-grid { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
  .impact-grid { grid-template-columns: repeat(2, 1fr); gap: 28px; }
  .impact-num { font-size: 40px; }
}

/* Scroll reveal */
.reveal {
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
